#!/bin/sh
#
# Pre-commit hook: prevent secrets and .env files from being committed.
# This is the last line of defence — the .gitignore is the first.
#

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Colour

FAILED=0

# ──────────────────────────────────────────────
# BLOCK 1: No .env files should ever be staged
# ──────────────────────────────────────────────
ENV_STAGED=$(git diff --cached --name-only -- '.env*' | grep -v '\.env\.example' || true)
if [ -n "$ENV_STAGED" ]; then
  echo "${RED}[BLOCKED]${NC} .env file(s) are staged for commit:"
  echo "$ENV_STAGED" | while read -r f; do echo "   $f"; done
  echo "${YELLOW}Hint:${NC} Add them to .gitignore or use 'git rm --cached' to untrack."
  FAILED=1
fi

# ──────────────────────────────────────────────
# BLOCK 2: Check for likely secrets in staged files
# ──────────────────────────────────────────────
# Patterns that strongly indicate a secret
SECRET_PATTERNS="(BEGIN\s+(RSA\s+)?PRIVATE\s+KEY|API[_-]KEY|SK-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36,}|xox[baprs]-[a-zA-Z0-9]{10,})"

STAGED_FILES=$(git diff --cached --name-only)
for file in $STAGED_FILES; do
  # Skip binary files
  if [ -f "$file" ] && git show ":${file}" | grep -qP "$SECRET_PATTERNS" 2>/dev/null; then
    # Only flag if it's not a .md doc or .githooks file referencing the pattern
    case "$file" in
      *.md|.githooks/*) ;;
      *)
        echo "${RED}[BLOCKED]${NC} Possible secret detected in: $file"
        echo "${YELLOW}Hint:${NC} Remove the secret, use environment variables, and check .gitignore."
        FAILED=1
        ;;
    esac
  fi
done

# ──────────────────────────────────────────────
# EXIT
# ──────────────────────────────────────────────
if [ "$FAILED" != "0" ]; then
  echo ""
  echo "${RED}Commit aborted.${NC} Fix the issues above and try again."
  exit 1
fi
